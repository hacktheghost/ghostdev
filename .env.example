# ghostdev configuration. Copy to .env and edit:  cp .env.example .env
# Nothing here is secret by default. NEVER commit your real .env (it is gitignored).

# ── Where the container is published on the host ────────────────────────────
# SAFE DEFAULT: localhost only. A web terminal is a remote shell — do not bind it to
# 0.0.0.0 / a public interface unless it sits behind a reverse proxy with auth.
GHOSTDEV_HOST_ADDR=127.0.0.1
GHOSTDEV_HOST_PORT=7680

# ── App ─────────────────────────────────────────────────────────────────────
# Label shown in the top bar (defaults to the container hostname if unset).
GHOSTDEV_NODE_LABEL=ghostdev

# Show your public/WAN IP in the top bar (calls api.ipify.org). Set false to disable.
GHOSTDEV_SHOW_PUBLIC_IP=true

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Built-in HTTP basic auth for the terminal. Leave empty and use a reverse proxy / SSO
# for anything beyond local/VPN use (see docs/SECURITY.md).
# GHOSTDEV_BASIC_AUTH=user:changeme

# Command each tab runs. Default attaches/creates a tmux session per tab.
# GHOSTDEV_SHELL=tmux new -A -s

# ── Optional Proxmox host stats (OFF by default) ───────────────────────────────
# Adds a "host" group to the top bar using a READ-ONLY Proxmox API token.
# NEVER use a root password. See docs/proxmox-stats.md for how to mint the token.
# GHOSTDEV_PROXMOX_ENABLED=true
# GHOSTDEV_PROXMOX_HOST=192.0.2.10
# GHOSTDEV_PROXMOX_TOKEN_ID=ghostdev@pve!stats
# GHOSTDEV_PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GHOSTDEV_PROXMOX_NODE=pve
