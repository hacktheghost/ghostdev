# ghostdev nginx — self-contained config, runs as a non-root user.
# Rendered by the entrypoint via envsubst (only ${NGINX_LISTEN} ${STATS_PORT} ${TTYD_PORT}
# are substituted; nginx runtime vars like $host are preserved).
worker_processes 1;
daemon off;
pid /tmp/ghostdev/nginx.pid;
error_log /dev/stderr warn;
events { worker_connections 256; }

http {
  access_log /dev/stdout;
  client_body_temp_path /tmp/ghostdev/body;
  proxy_temp_path       /tmp/ghostdev/proxy;
  fastcgi_temp_path     /tmp/ghostdev/fastcgi;
  uwsgi_temp_path       /tmp/ghostdev/uwsgi;
  scgi_temp_path        /tmp/ghostdev/scgi;
  include /etc/nginx/mime.types;
  default_type application/octet-stream;
  sendfile on;

  server {
    listen ${NGINX_LISTEN} default_server;
    listen [::]:${NGINX_LISTEN} default_server;
    server_name _;
    root /var/www/ghostdev;
    index index.html;

    # stats / sessions / file-explorer backend
    location /api/ {
      proxy_pass http://127.0.0.1:${STATS_PORT}/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      client_max_body_size 256m;        # file uploads
      proxy_read_timeout 600;           # large uploads / URL downloads
      proxy_send_timeout 600;
    }

    # ttyd (terminal) under base-path /tty with websocket upgrade
    location /tty {
      proxy_pass http://127.0.0.1:${TTYD_PORT};
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_read_timeout 86400;
      proxy_send_timeout 86400;
    }

    location / {
      try_files $uri $uri/ /index.html;
    }
  }
}
