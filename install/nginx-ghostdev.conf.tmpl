# ghostdev nginx site (native install). Drops into /etc/nginx/sites-available/.
# SAFE DEFAULT: listens on localhost only. A web terminal is a remote shell — put a
# reverse proxy + auth in front before exposing it. See docs/reverse-proxy.md.
server {
    listen ${GHOSTDEV_BIND}:${GHOSTDEV_PORT};
    server_name _;
    root /var/www/ghostdev;
    index index.html;

    # stats / sessions backend
    location /api/ {
        proxy_pass http://127.0.0.1:9090/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_read_timeout 15;
    }

    # ttyd (terminal) under base-path /tty with websocket upgrade
    location /tty {
        proxy_pass http://127.0.0.1:7681;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
